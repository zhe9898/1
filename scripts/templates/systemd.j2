# ZEN70 systemd unit — Auto Generated by scripts/compiler.py
# Source of truth: system.yaml  runtime: host
# Do NOT edit manually — re-run compiler.py to regenerate.

[Unit]
Description={{ svc.description }}
After={{ svc.after }}

[Service]
Type=simple
{% if svc.environment_file %}EnvironmentFile={{ svc.environment_file }}
{% endif %}{% for line in svc.environment_lines %}Environment={{ line }}
{% endfor %}ExecStart={{ svc.exec_start }}
{% if svc.user %}User={{ svc.user }}
{% endif %}{% if svc.group %}Group={{ svc.group }}
{% endif %}{% if svc.working_dir %}WorkingDirectory={{ svc.working_dir }}
{% endif %}Restart={{ svc.restart }}
RestartSec={{ svc.restart_sec }}
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
