{
  "name": "zen70-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.gateway.json && vite build",
    "build:full": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "commitlint": "commitlint --edit",
    "lint": "vue-tsc --noEmit -p tsconfig.gateway.json && eslint .",
    "lint:full": "vue-tsc --noEmit && eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "axios": "^1.6.0",
    "dexie": "^3.2.7",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@eslint/js": "^9.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.1.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.0",
    "axios-mock-adapter": "^2.1.0",
    "daisyui": "^4.4.19",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.2.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.4.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.1.0",
    "vue-eslint-parser": "^9.0.0",
    "vue-tsc": "^2.2.0"
  },
  "overrides": {
    "esbuild": ">=0.25.0",
    "glob": ">=11.0.0",
    "serialize-javascript": ">=7.0.4"
  }
}
