# @generated by ZEN70-AI-Agent
# @architecture-version: V2.0
# @compliance: strict-sre-ruleset
# WARNING: Auto-generated coverage config. Manual modifications may be overwritten.
#
# 覆盖率配置：CI 单元测试门禁
# - sentinel/ 和 workers/ 需要 Docker/Redis/硬件，属于 integration/chaos 测试范畴
# - main.py 仅 uvicorn 入口
# - core/rls.py 需要 PostgreSQL

[run]
source = .
omit =
    */tests/*
    sentinel/*
    workers/*
    main.py
    core/rls.py

[report]
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    @overload
    raise NotImplementedError
    \.\.\.
show_missing = true
