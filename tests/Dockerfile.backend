# Integration-test backend image: boot the canonical gateway entrypoint from the repo root.
# Usage: docker build -f tests/Dockerfile.backend -t zen70-test-backend .
ARG PYTHON=3.12-slim
FROM ${PYTHON}
WORKDIR /app
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

# Backend dependencies.
COPY backend/requirements.txt backend/requirements.txt
RUN pip install --no-cache-dir -r backend/requirements.txt
COPY backend ./backend

# Default to the canonical gateway entrypoint; tests can override with `command`.
CMD ["uvicorn", "backend.control_plane.app.entrypoint:app", "--host", "0.0.0.0", "--port", "8000"]
