FROM python:3.12-slim
WORKDIR /app
ENV PYTHONPATH=/app
COPY backend/requirements.txt backend/requirements.txt
RUN pip install --no-cache-dir -r backend/requirements.txt && pip install --no-cache-dir pytest pytest-asyncio requests httpx
COPY backend ./backend
COPY tests ./tests
CMD ["python", "-m", "pytest", "--tb=short", "-v", "-q"]
